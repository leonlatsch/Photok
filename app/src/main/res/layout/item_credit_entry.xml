<?xml version="1.0" encoding="utf-8"?><?xml version="1.0" encoding="utf-8"?>


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/small_gap"
    tools:ignore="HardcodedText">

    <TextView
        android:id="@+id/creditName"
        style="@style/LabelTextViewStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="@dimen/small_gap"
        android:text="NAME"
        app:drawableStartCompat="@drawable/ic_person" />

    <TextView
        android:id="@+id/creditContribution"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/big_gap"
        android:text="CONTRIBUTION" />

    <TextView
        android:id="@+id/creditContact"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="@dimen/small_gap"
        android:text="CONTACT"
        android:textColor="@color/secondaryTextColor"
        app:drawableStartCompat="@drawable/ic_email" />

    <TextView
        android:id="@+id/creditWebsite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="@dimen/small_gap"
        android:text="WEBSITE"
        android:textColor="@color/secondaryTextColor"
        app:drawableStartCompat="@drawable/ic_web" />

</LinearLayout>

